@startuml
title Mediator Pattern - Guild System

interface GuildMediator {
  +send(message: String, topic: String, sender: GuildMember): void
  +register(member: GuildMember): void
}

abstract class GuildMember {
  -name: String
  -mediator: GuildMediator
  +send(message: String, topic: String): void
  +receive(message: String, topic: String): void
  +getName(): String
}

class GuildHall {
  -members: List<GuildMember>
  +register(member: GuildMember): void
  +send(message: String, topic: String, sender: GuildMember): void
}

class Quartermaster
class Scout
class Healer
class Captain
class Loremaster

GuildMediator <|.. GuildHall
GuildMember <|-- Quartermaster
GuildMember <|-- Scout
GuildMember <|-- Healer
GuildMember <|-- Captain
GuildMember <|-- Loremaster

GuildHall o-- GuildMember
GuildMember --> GuildMediator

@enduml
